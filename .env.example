# ── SomaPulse Backend ────────────────────────────────────────
# Local FastAPI daemon URL (all inference is local)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Optional: Whisper Model Path ─────────────────────────────
# Path to local whisper.cpp GGML model file
# WHISPER_MODEL_PATH=/path/to/ggml-base.en.bin

# ── Optional: SapBERT Model Path ─────────────────────────────
# Path to local SapBERT ONNX model file
# SAPBERT_MODEL_PATH=/path/to/sapbert.onnx
